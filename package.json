{
  "name": "rag",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0 <22.0.0"
  },
  "scripts": {
    "dev": "npx -y node@20 ./node_modules/next/dist/bin/next dev -H 0.0.0.0",
    "build": "npx -y node@20 ./node_modules/next/dist/bin/next build",
    "start": "npx -y node@20 ./node_modules/next/dist/bin/next start",
    "lint": "eslint",
    "db:up": "./.venv/bin/milvus-server --data ./milvus_data",
    "db:down": "pkill -f milvus-server",
    "milvus:start": "source venv/bin/activate && python scripts/start_milvus.py"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "@langchain/classic": "^1.0.30",
    "@langchain/cohere": "^1.0.4",
    "@langchain/community": "^1.1.27",
    "@langchain/core": "^1.1.39",
    "@langchain/openai": "^1.4.4",
    "@langchain/textsplitters": "^1.0.1",
    "@xenova/transformers": "^2.17.2",
    "@zilliz/milvus2-sdk-node": "^2.6.13",
    "cheerio": "^1.2.0",
    "chromadb": "^3.4.3",
    "d3-dsv": "^3.0.1",
    "langchain": "^1.3.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "pdf-parse": "^1.1.1",
    "pdfjs-dist": "^5.6.205",
    "pdfkit": "^0.18.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5"
  }
}
